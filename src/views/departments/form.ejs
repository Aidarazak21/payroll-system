<div class="card shadow-sm" style="max-width: 600px; margin: 0 auto;">
    <div class="card-body p-4">
        <h2 class="mb-4"><%= typeof department !== 'undefined' ? 'Edit Department' : 'Add New Department' %></h2>
        
        <form action="<%= typeof department !== 'undefined' ? '/departments/' + department.id : '/departments' %>" method="POST">
            <div class="mb-3">
                <label for="name" class="form-label">Department Name</label>
                <input type="text" id="name" name="name" class="form-control" value="<%= typeof department !== 'undefined' ? department.name : '' %>" required>
            </div>
            
            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Save Department</button>
                <a href="/departments" class="btn btn-light ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>
