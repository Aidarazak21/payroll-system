<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Departments</h2>
    <a href="/departments/create" class="btn btn-primary">Add New Department</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <% if (typeof departments !== 'undefined' && departments.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Created At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% departments.forEach(function(dept) { %>
                            <tr>
                                <td><%= dept.id %></td>
                                <td><%= dept.name %></td>
                                <td><%= new Date(dept.created_at).toLocaleDateString() %></td>
                                <td>
                                    <a href="/departments/<%= dept.id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <form action="/departments/<%= dept.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this department?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="text-center text-muted p-4">
                <p>No departments found. Click 'Add New Department' to create one.</p>
            </div>
        <% } %>
    </div>
</div>
