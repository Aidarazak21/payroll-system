<div class="mb-4 no-print">
    <a href="/payroll/history" class="text-decoration-none text-secondary">
        <i class="bi bi-arrow-left"></i> &larr; Back to History
    </a>
</div>

<div class="card shadow-sm border-0 payslip-container" style="max-width: 900px; margin: 0 auto; background: white;">
    <div class="card-body p-5">
        
        <!-- Company Header -->
        <div class="row mb-4 pb-3 border-bottom border-dark border-2">
            <div class="col-8">
                <h2 class="text-primary fw-bold mb-1">ABC System Sdn. Bhd.</h2>
                <p class="text-muted mb-0 small">123, Jalan Corporate, 50000 Kuala Lumpur</p>
            </div>
            <div class="col-4 text-end">
                <h3 class="fw-bold text-uppercase mb-1">Payslip</h3>
                <h5 class="text-muted"><%= typeof record !== 'undefined' ? (record.month + '/' + record.year) : 'N/A' %></h5>
            </div>
        </div>
        
        <% if (typeof record !== 'undefined') { %>
            <!-- Employee Details -->
            <div class="row mb-4 g-3 bg-light p-3 rounded border">
                <div class="col-md-6">
                    <div class="d-flex mb-1">
                        <span class="text-muted" style="width: 120px;">Employee Name:</span>
                        <strong class="text-dark"><%= record.employee_name %></strong>
                    </div>
                    <div class="d-flex mb-1">
                        <span class="text-muted" style="width: 120px;">Position:</span>
                        <strong class="text-dark"><%= record.position %></strong>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex mb-1">
                        <span class="text-muted" style="width: 120px;">Department:</span>
                        <strong class="text-dark"><%= record.department_name %></strong>
                    </div>
                    <div class="d-flex mb-1">
                        <span class="text-muted" style="width: 120px;">Pay Date:</span>
                        <strong class="text-dark"><%= new Date(record.created_at).toLocaleDateString() %></strong>
                    </div>
                </div>
            </div>
            
            <!-- Horizontal Layout: Earnings vs Deductions -->
            <div class="row mb-3">
                <!-- Earnings Column -->
                <div class="col-6">
                    <div class="border rounded h-100">
                        <div class="bg-light p-2 border-bottom fw-bold text-center">EARNINGS</div>
                        <table class="table table-borderless table-sm mb-0 p-2">
                            <tbody>
                                <tr>
                                    <td class="ps-3 py-1">Basic Salary</td>
                                    <td class="text-end pe-3 py-1">RM <%= parseFloat(record.basic_salary).toFixed(2) %></td>
                                </tr>
                                <tr>
                                    <td class="ps-3 py-1">Fixed Allowance</td>
                                    <td class="text-end pe-3 py-1">RM <%= parseFloat(record.allowance).toFixed(2) %></td>
                                </tr>
                                <tr>
                                    <td class="ps-3 py-1">Overtime Pay</td>
                                    <td class="text-end pe-3 py-1">RM <%= parseFloat(record.overtime_pay).toFixed(2) %></td>
                                </tr>
                            </tbody>
                        </table>
                        <div class="border-top px-3 py-2 bg-light mt-auto">
                            <div class="d-flex justify-content-between fw-bold">
                                <span>TOTAL EARNINGS</span>
                                <span>RM <%= parseFloat(record.gross_pay).toFixed(2) %></span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Deductions Column -->
                <div class="col-6">
                    <div class="border rounded h-100">
                        <div class="bg-light p-2 border-bottom fw-bold text-center text-danger">DEDUCTIONS</div>
                        <table class="table table-borderless table-sm mb-0 p-2">
                            <tbody>
                                <tr>
                                    <td class="ps-3 py-1">Income Tax (8%)</td>
                                    <td class="text-end pe-3 py-1">RM <%= parseFloat(record.tax).toFixed(2) %></td>
                                </tr>
                                <tr>
                                    <td class="ps-3 py-1">EPF Employee (11%)</td>
                                    <td class="text-end pe-3 py-1">RM <%= parseFloat(record.epf_employee).toFixed(2) %></td>
                                </tr>
                            </tbody>
                        </table>
                        <div class="border-top px-3 py-2 bg-light mt-auto">
                            <div class="d-flex justify-content-between fw-bold text-danger">
                                <span>TOTAL DEDUCTIONS</span>
                                <span>RM <%= (parseFloat(record.tax) + parseFloat(record.epf_employee)).toFixed(2) %></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Net Pay Summary Box aligned right below deductions -->
            <div class="row mb-4">
                <div class="col-6 offset-6">
                    <div class="border rounded border-primary bg-primary text-white p-2 shadow-sm">
                        <div class="d-flex justify-content-between align-items-center px-2">
                            <h5 class="mb-0">NET PAY</h5>
                            <h4 class="mb-0 fw-bold">RM <%= parseFloat(record.net_pay).toFixed(2) %></h4>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Footer Notes -->
            <div class="row border-top pt-2 text-muted small">
                <div class="col-12">
                    <p class="mb-1"><strong>Employer EPF Contribution (13%):</strong> RM <%= parseFloat(record.epf_employer).toFixed(2) %></p>
                    <p class="mb-0"><em>This is a computer generated document. No signature is required.</em></p>
                </div>
            </div>
            
            <!-- Print Button -->
            <div class="text-center mt-4 no-print">
                <button onclick="window.print()" class="btn btn-primary px-5 shadow-sm">
                    <i class="bi bi-printer me-2"></i> Print Payslip
                </button>
            </div>
            
            <style>
                .payslip-container { box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important; }
                @media print {
                    @page { size: auto; margin: 5mm; }
                    .navbar, .sidebar, .no-print, a, hr { display: none !important; }
                    .main-content { margin-left: 0 !important; width: 100% !important; padding: 0 !important; }
                    .container-fluid { padding: 0 !important; }
                    body { background: white !important; font-size: 11pt; padding: 0 !important; }
                    .payslip-container { box-shadow: none !important; border: none !important; padding: 0 !important; margin: 0 !important; max-width: 100% !important; }
                    .card-body { padding: 5px !important; }
                    .border { border-color: #333 !important; }
                    .text-primary { color: #000 !important; }
                    .bg-light { background-color: #f1f1f1 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
                    .bg-primary { background-color: #000 !important; color: white !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; border-color: #000 !important; }
                    .row { margin-left: 0; margin-right: 0; }
                    .col-6 { width: 50% !important; float: left; }
                }
            </style>
        <% } else { %>
            <div class="alert alert-danger text-center">Record not found.</div>
        <% } %>
    </div>
</div>
